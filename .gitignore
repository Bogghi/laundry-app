# Mono-repo root .gitignore for Flutter apps

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
.vscode/

# Flutter/Dart/Pub related (applies to all Flutter apps in the mono-repo)
**/doc/api/
**/ios/Flutter/.last_build_id
**/.dart_tool/
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/build/
**/coverage/

# Flutter package specific patterns (shared_assets)
shared_assets/pubspec.lock
shared_assets/doc/api/
shared_assets/.dart_tool/
shared_assets/.flutter-plugins-dependencies
shared_assets/build/
shared_assets/coverage/

# Android Studio will place build artifacts here (for all apps)
**/android/app/debug
**/android/app/profile
**/android/app/release

# Symbolication and obfuscation files
**/app.*.symbols
**/app.*.map.json

# Flutter app specific patterns
# Note: Apps directories are tracked, but their build outputs are ignored by patterns above

# Ignore unused platform directories for Flutter apps
**/linux/
**/macos/
**/web/
**/windows/